Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SeparatePowers", "=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"VPower", "=", 
         RowBox[{"Verbatim", "[", "Power", "]"}]}], ",", 
        RowBox[{"VPlus", "=", 
         RowBox[{"Verbatim", "[", "Plus", "]"}]}], ",", 
        RowBox[{"VTimes", "=", 
         RowBox[{"Verbatim", "[", "Times", "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"VPower", "[", 
          RowBox[{
           RowBox[{"VTimes", "[", "a__", "]"}], ",", "b_"}], "]"}], ":>", 
         RowBox[{
          RowBox[{"Inactive", "[", "Times", "]"}], "@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Power", "[", 
               RowBox[{"#", ",", "b"}], "]"}], "&"}], ")"}], "/@", 
            RowBox[{"(", 
             RowBox[{"List", "[", "a", "]"}], ")"}]}], ")"}]}]}], ",", 
        RowBox[{
         RowBox[{"VPower", "[", 
          RowBox[{
           RowBox[{"VPower", "[", 
            RowBox[{"a_", ",", "b_"}], "]"}], ",", "c_"}], "]"}], ":>", 
         RowBox[{"Power", "[", 
          RowBox[{"a", ",", 
           RowBox[{"Times", "[", 
            RowBox[{"b", ",", "c"}], "]"}]}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"VPower", "[", 
          RowBox[{"a__", ",", 
           RowBox[{"VPlus", "[", "b__", "]"}]}], "]"}], ":>", 
         RowBox[{
          RowBox[{"Inactive", "[", "Times", "]"}], "@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Power", "[", 
               RowBox[{"a", ",", "#"}], "]"}], "&"}], ")"}], "/@", 
            RowBox[{"List", "[", "b", "]"}]}], ")"}]}]}], ",", 
        RowBox[{
         RowBox[{"VPower", "[", 
          RowBox[{"a_", ",", 
           RowBox[{"VTimes", "[", 
            RowBox[{"c__", "/;", 
             RowBox[{"MemberQ", "[", 
              RowBox[{
               RowBox[{"List", "[", "c", "]"}], ",", "VPlus", ",", 
               RowBox[{"{", "2", "}"}], ",", 
               RowBox[{"Heads", "->", "True"}]}], "]"}]}], "]"}]}], "]"}], ":>", 
         RowBox[{"Power", "[", 
          RowBox[{"a", ",", 
           RowBox[{"Distribute", "[", 
            RowBox[{"Times", "[", "c", "]"}], "]"}]}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"VPower", "[", 
          RowBox[{"a_", ",", 
           RowBox[{"VPlus", "[", 
            RowBox[{
             RowBox[{"VTimes", "[", 
              RowBox[{"c__", "/;", 
               RowBox[{"MemberQ", "[", 
                RowBox[{
                 RowBox[{"List", "[", "c", "]"}], ",", "VPlus", ",", 
                 RowBox[{"{", "2", "}"}], ",", 
                 RowBox[{"Heads", "->", "True"}]}], "]"}]}], "]"}], ",", 
             "b__"}], "]"}]}], "]"}], ":>", 
         RowBox[{"Power", "[", 
          RowBox[{"a", ",", 
           RowBox[{"Map", "[", 
            RowBox[{"Distribute", ",", 
             RowBox[{"Plus", "[", 
              RowBox[{"b", ",", 
               RowBox[{"Times", "[", "c", "]"}]}], "]"}], ",", "Infinity"}], 
            "]"}]}], "]"}]}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z2rules", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Eta]", "[", "x_", "]"}], "^", 
       RowBox[{"Times", "[", 
        RowBox[{
         RowBox[{"j_", "?", "Negative"}], ",", "k_"}], "]"}]}], "->", 
      RowBox[{
       RowBox[{"\[Eta]", "[", "x", "]"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "k"}], " ", "j"}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Eta]", "[", "x_", "]"}], "^", 
       RowBox[{"Times", "[", 
        RowBox[{
         RowBox[{"j_", "?", "EvenQ"}], ",", 
         RowBox[{"m_", ":", "1"}]}], "]"}]}], "->", "1"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Eta]", "[", "x_", "]"}], "^", 
       RowBox[{"Times", "[", 
        RowBox[{
         RowBox[{"j_", "?", "OddQ"}], ",", 
         RowBox[{"m_", ":", "1"}]}], "]"}]}], "->", 
      RowBox[{
       RowBox[{"\[Eta]", "[", "x", "]"}], "^", 
       RowBox[{"(", "m", ")"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Eta]", "[", "x_", "]"}], "^", 
       RowBox[{"Power", "[", 
        RowBox[{"j_", ",", "n_"}], "]"}]}], "->", 
      RowBox[{
       RowBox[{"\[Eta]", "[", "x", "]"}], "^", "j"}]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SeparateAndApplyZ2", "[", "expr_", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"expr", "//.", "SeparatePowers"}], "//.", "z2rules"}], "//.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Inactive", "[", "Times", "]"}], "->", "Times"}], "}"}]}], 
    ")"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"z2Simplify", "[", "expr_", "]"}], ":=", 
   RowBox[{"FixedPoint", "[", 
    RowBox[{"SeparateAndApplyZ2", ",", "expr"}], "]"}]}], 
  ";"}], "\n"}], "Input",
