         ")"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cond", " ", "=", " ", 
      RowBox[{
       RowBox[{"Times", "@@", "cases"}], "/.", 
       RowBox[{"{", 
