          RowBox[{
           RowBox[{"eqSet", "[", 
            RowBox[{"[", "eqNo", "]"}], "]"}], ",", "#"}], "]"}], "&"}], "/@",
         "eqSet"}]}], ";", "\[IndentingNewLine]", 
