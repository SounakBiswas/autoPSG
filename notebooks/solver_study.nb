    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FuseReductionConstraints", "[", 
      RowBox[{"c1_", ",", "c2_"}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Not", "[", 
        RowBox[{"MatchQ", "[", 
