Cell[BoxData[{
 RowBox[{
  RowBox[{"IsolateRelationConstraint", "[", 
   RowBox[{"expr_", ",", "a_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"cases", ",", "cond"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"cases", "=", " ", 
      RowBox[{"Cases", "[", 
       RowBox[{"expr", ",", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Power", "[", 
           RowBox[{"__", ",", "a"}], "]"}], "|", 
          RowBox[{"Power", "[", 
           RowBox[{"__", ",", 
            RowBox[{"HoldPattern", "[", 
             RowBox[{"Plus", "[", 
              RowBox[{"___", ",", "a", ",", "___"}], "]"}], "]"}]}], "]"}]}], 
         ")"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cond", " ", "=", " ", 
      RowBox[{
       RowBox[{"Times", "@@", "cases"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Power", "[", 
          RowBox[{"b_", ",", "__"}], "]"}], "\[Rule]", "b"}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "cases", "]"}], "\[NotEqual]", "0"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Equation", "[", 
