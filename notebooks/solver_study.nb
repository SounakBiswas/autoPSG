           RowBox[{
            RowBox[{"Fold", "[", 
             RowBox[{"ReplaceAll", ",", 
              RowBox[{
               RowBox[{"F", "[", "A", "]"}], "[", 
               RowBox[{"{", 
                RowBox[{"x", ",", "y"}], "}"}], "]"}], ",", "#"}], "]"}], 
            "&"}], ")"}], "/@", 
          RowBox[{"Permutations", "[", "redsA", "]"}]}], ",", 
         "\[IndentingNewLine]", "Nothing"}], "]"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
