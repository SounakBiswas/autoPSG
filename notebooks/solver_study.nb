      RowBox[{
       RowBox[{"Verbatim", "[", "Plus", "]"}], "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Verbatim", "[", "Times", "]"}], "[", 
         RowBox[{"c$__", "/;", 
          RowBox[{"MemberQ", "[", 
           RowBox[{
            RowBox[{"{", "c$", "}"}], ",", 
            RowBox[{"Verbatim", "[", "Plus", "]"}], ",", 
            RowBox[{"{", "2", "}"}], ",", 
            RowBox[{"Heads", "\[Rule]", "True"}]}], "]"}]}], "]"}], ",", 
        "b$__"}], "]"}]}], "]"}], "\[RuleDelayed]", 
    SuperscriptBox["a$", 
     RowBox[{"Map", "[", 
      RowBox[{"Distribute", ",", 
