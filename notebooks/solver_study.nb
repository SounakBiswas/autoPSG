           RowBox[{"{", 
            RowBox[{"reds", "=", 
             RowBox[{"FilterReductions", "[", 
              RowBox[{
               RowBox[{"F", "[", "#", "]"}], ",", "reductions"}], "]"}]}], 
            "}"}], ",", " ", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Length", "[", "reds", "]"}], "!=", "0"}], ",", " ", 
             "\[IndentingNewLine]", 
