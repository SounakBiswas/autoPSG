Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{" ", 
    RowBox[{
    "Get", " ", "reductions", " ", "for", " ", "a", " ", "parituclar", " ", 
     RowBox[{"F", "[", "A"}]}], "}"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FilterReductions", "[", 
      RowBox[{
       RowBox[{"F", "[", "A_", "]"}], ",", "reductions_"}], "]"}], ":=", 
     RowBox[{"Cases", "[", 
      RowBox[{"reductions", ",", 
       RowBox[{"HoldPattern", "[", 
        RowBox[{"Rule", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"F", "[", "A", "]"}], "[", "coord_", "]"}], ",", "x___"}], 
         "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Get", " ", 
     RowBox[{"F", "[", "A", "]"}], " ", "obtained", " ", "through", " ", 
     "different", " ", "reduction", " ", "paths"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ComposeReductionPaths", "[", 
      RowBox[{
       RowBox[{"F", "[", "A_", "]"}], ",", "reductions_"}], "]"}], ":=", 
     "\[IndentingNewLine]", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"redsA", "=", 
         RowBox[{"FilterReductions", "[", 
          RowBox[{
           RowBox[{"F", "[", "A", "]"}], ",", "reductions"}], "]"}]}], "}"}], 
       ",", " ", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "redsA", "]"}], "!=", "0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Fold", "[", 
             RowBox[{"ReplaceAll", ",", 
              RowBox[{
               RowBox[{"F", "[", "A", "]"}], "[", 
               RowBox[{"{", 
                RowBox[{"x", ",", "y"}], "}"}], "]"}], ",", "#"}], "]"}], 
            "&"}], ")"}], "/@", 
          RowBox[{"Permutations", "[", "redsA", "]"}]}], ",", 
         "\[IndentingNewLine]", "Nothing"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FReductionPaths", "[", "reductions_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ComposeReductionPaths", "[", 
         RowBox[{
          RowBox[{"F", "[", "#", "]"}], ",", "reductions"}], "]"}], "&"}], "/@",
        "symGenSet"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"F", "[", "A_", "]"}], "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], "]"}], "->", "1"}], "}"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FuseReductionConstraints", "[", 
      RowBox[{"c1_", ",", "c2_"}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Not", "[", 
        RowBox[{"MatchQ", "[", 
         RowBox[{"c1", ",", "c2"}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"Equation", "[", 
         RowBox[{"c1", ",", "c2"}], "]"}], "}"}], ",", "Nothing"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"IfDuplicateEquation", "[", 
      RowBox[{
       RowBox[{"HoldPattern", "[", 
        RowBox[{"Equation", "[", 
         RowBox[{"a_", ",", "b_"}], "]"}], "]"}], ",", 
       RowBox[{"HoldPattern", "[", 
        RowBox[{"Equation", "[", 
         RowBox[{"c_", ",", "d_"}], "]"}], "]"}]}], "]"}], ":=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"SameQ", "[", 
         RowBox[{"a", ",", "c"}], "]"}], "&&", 
        RowBox[{"SameQ", "[", 
         RowBox[{"b", ",", "d"}], "]"}]}], ")"}], "||", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"SameQ", "[", 
         RowBox[{"a", ",", "d"}], "]"}], " ", "&&", " ", 
        RowBox[{"SameQ", "[", 
         RowBox[{"b", ",", "c"}], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FuseReductionConstraintsList", "[", "clist_", "]"}], ":=", " ", 
     "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "x", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "clist", "]"}], ">=", "1"}], " ", "&&", " ", 
          RowBox[{"Not", "[", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"clist", ",", "Null"}], "]"}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "=", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"FuseReductionConstraints", "[", 
                RowBox[{
                 RowBox[{"clist", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", "#"}], "]"}], "&"}], "/@", 
              RowBox[{"Drop", "[", 
               RowBox[{"clist", ",", "1"}], "]"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"x", "=", 
            RowBox[{"z2Simplify", "[", "x", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"x", "=", " ", 
            RowBox[{"DeleteCases", "[", 
             RowBox[{"x", ",", 
              RowBox[{"y_", "/;", 
               RowBox[{"IfTrivialEquation", "[", "y", "]"}]}]}], "]"}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"x", "=", 
            RowBox[{"DeleteDuplicates", "[", 
             RowBox[{"x", ",", "IfDuplicateEquation"}], "]"}]}]}], ")"}], ",",
          "\[IndentingNewLine]", "Nothing"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FReductionConstraints", "[", "reductions_", "]"}], ":=", 
     RowBox[{"Join", "@@", 
      RowBox[{"FuseReductionConstraintsList", "/@", 
       RowBox[{"FReductionPaths", "[", "reductions", "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FReductions", "[", "reductions_", "]"}], ":=", 
     "\[IndentingNewLine]", 
     RowBox[{"Association", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"reds", "=", 
             RowBox[{"FilterReductions", "[", 
              RowBox[{
               RowBox[{"F", "[", "#", "]"}], ",", "reductions"}], "]"}]}], 
            "}"}], ",", " ", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Length", "[", "reds", "]"}], "!=", "0"}], ",", " ", 
             "\[IndentingNewLine]", 
             RowBox[{"#", "->", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"F", "[", "#", "]"}], "[", 
                 RowBox[{"{", 
                  RowBox[{"x_", ",", "y_"}], "}"}], "]"}], "->", 
                RowBox[{"Fold", "[", 
                 RowBox[{"ReplaceAll", ",", 
                  RowBox[{
                   RowBox[{"F", "[", "#", "]"}], "[", 
                   RowBox[{"{", 
                    RowBox[{"x", ",", "y"}], "}"}], "]"}], ",", "reds"}], 
                 "]"}]}], ")"}]}], ",", "\[IndentingNewLine]", "Nothing"}], 
            "]"}]}], "]"}], "&"}], " ", "/@", "symGenSet"}], " ", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"F", "[", "A_", "]"}], "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], "]"}], "->", "1"}], "}"}]}], 
      "]"}]}], ";"}]}]}]], "Input",
