 RowBox[{
  RowBox[{
   RowBox[{"substEq", "[", 
    RowBox[{
     RowBox[{"HoldPattern", "[", 
      RowBox[{"Equation", "[", 
       RowBox[{
        RowBox[{"CenterDot", "[", "y__", "]"}], ",", "rhs1_"}], "]"}], "]"}], 
     ",", " ", 
