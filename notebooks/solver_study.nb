      RowBox[{"Equation", "[", 
       RowBox[{
        RowBox[{"CenterDot", "[", 
         RowBox[{"x___", ",", "y__", ",", "z___"}], "]"}], ",", "rhs2_"}], 
       "]"}], "]"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Equation", "[", 
    RowBox[{
     RowBox[{"CenterDot", "[", 
      RowBox[{"x", ",", "z"}], "]"}], ",", 
     RowBox[{"rhs2", " ", 
      SuperscriptBox["rhs1", 
       RowBox[{"-", "1"}]]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"substEq", "[", 
    RowBox[{"eq1_Equation", ",", "eq2_Equation"}], "]"}], ":=", "Nothing"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"replaceMEqIntoMEq", "[", 
    RowBox[{
     RowBox[{"eq1", ":", 
      RowBox[{"HoldPattern", "[", 
       RowBox[{"Equation", "[", 
        RowBox[{
         RowBox[{"CenterDot", "[", "x1__", "]"}], ",", "rhs1_"}], "]"}], 
       "]"}]}], ",", 
     RowBox[{"eq2", ":", 
      RowBox[{"HoldPattern", "[", 
       RowBox[{"Equation", "[", 
        RowBox[{
         RowBox[{"CenterDot", "[", "x2__", "]"}], ",", "rhs2_"}], "]"}], 
       "]"}]}]}], "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "newEq", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"newEq", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"substEq", "[", 
          RowBox[{
           RowBox[{"Equation", "[", 
            RowBox[{
             RowBox[{"RotateLeft", "[", 
              RowBox[{
               RowBox[{"eq1", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", "#"}], "]"}], ",", 
             "rhs1"}], "]"}], ",", "eq2"}], "]"}], "&"}], "/@", 
        RowBox[{"Range", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Length", "[", 
           RowBox[{"eq1", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "newEq", "]"}], "\[NotEqual]", " ", "0"}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"newEq", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", "\[IndentingNewLine]", "eq2"}], 
       "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"replaceMEqIntoMEq", "[", 
    RowBox[{"eq1_", ",", "eq2_"}], "]"}], ":=", "eq2"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"replaceMEqIntoAllMEqs", "[", 
    RowBox[{"eqSet_", ",", "eqNo_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "newEqSet", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"newEqSet", "=", 
