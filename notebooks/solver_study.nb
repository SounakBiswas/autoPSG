   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ComposeReductionPaths", "[", 
      RowBox[{
       RowBox[{"F", "[", "A_", "]"}], ",", "reductions_"}], "]"}], ":=", 
     "\[IndentingNewLine]", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"redsA", "=", 
