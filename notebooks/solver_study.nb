               RowBox[{"F", "[", "A", "]"}], "[", 
               RowBox[{"{", 
                RowBox[{"x", ",", "y"}], "}"}], "]"}], ",", "#"}], "]"}], 
            "&"}], ")"}], "/@", 
          RowBox[{"Permutations", "[", "redsA", "]"}]}], ",", 
         "\[IndentingNewLine]", "Nothing"}], "]"}]}], "]"}]}], ";"}], 
