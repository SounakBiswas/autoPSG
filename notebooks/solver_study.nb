Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Verbatim", "[", "Power", "]"}], "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Verbatim", "[", "Times", "]"}], "[", "a__", "]"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"c_", ":", "1"}], ")"}], "+", "b_"}]}], "]"}], 
    "\[RuleDelayed]", 
    RowBox[{
     SuperscriptBox["a", "c"], " ", 
     RowBox[{
      RowBox[{"Inactive", "[", "Times", "]"}], "@@", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["#1", "b"], "&"}], ")"}], "/@", 
       RowBox[{"{", "a", "}"}]}]}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Verbatim", "[", "Power", "]"}], "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Verbatim", "[", "Power", "]"}], "[", 
       RowBox[{"a_", ",", "b_"}], "]"}], ",", "c_"}], "]"}], "\[RuleDelayed]", 
    SuperscriptBox["a", 
     RowBox[{"b", " ", "c"}]]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Verbatim", "[", "Power", "]"}], "[", 
     RowBox[{"a__", ",", 
      RowBox[{
       RowBox[{"Verbatim", "[", "Plus", "]"}], "[", "b__", "]"}]}], "]"}], 
    "\[RuleDelayed]", 
    RowBox[{
     RowBox[{"Inactive", "[", "Times", "]"}], "@@", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["a", "#1"], "&"}], ")"}], "/@", 
      RowBox[{"{", "b", "}"}]}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Verbatim", "[", "Power", "]"}], "[", 
     RowBox[{"a$_", ",", 
      RowBox[{
       RowBox[{"Verbatim", "[", "Times", "]"}], "[", 
       RowBox[{"c$__", "/;", 
        RowBox[{"MemberQ", "[", 
         RowBox[{
          RowBox[{"{", "c$", "}"}], ",", 
          RowBox[{"Verbatim", "[", "Plus", "]"}], ",", 
          RowBox[{"{", "2", "}"}], ",", 
          RowBox[{"Heads", "\[Rule]", "True"}]}], "]"}]}], "]"}]}], "]"}], 
    "\[RuleDelayed]", 
    SuperscriptBox["a$", 
     RowBox[{"Distribute", "[", 
      RowBox[{"Times", "[", "c$", "]"}], "]"}]]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Verbatim", "[", "Power", "]"}], "[", 
