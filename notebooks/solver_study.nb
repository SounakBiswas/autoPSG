Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"setSlatGauges2", "[", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Dependency", ",", "trySettingSlatGauge", ",", "findAllDependencies", 
       ",", "Relations"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Dependency", "=", " ", 
       RowBox[{"Association", " ", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "->", "Null"}], "&"}], "/@", "slatList"}], ")"}]}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"findAllDependencies", "[", "a_", "]"}], ":=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Dependency", "[", "a", "]"}], "===", "Null"}], ",", 
         RowBox[{"{", "}"}], ",", " ", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Dependency", "[", "a", "]"}], "}"}], ",", 
           RowBox[{"findAllDependencies", "[", 
            RowBox[{"Dependency", "[", "a", "]"}], "]"}]}], "]"}]}], "]"}]}], 
      ";", " ", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"trySettingSlatGauge", "[", 
        RowBox[{"A_", ",", "a_"}], "]"}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", "newSlat", "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"newSlat", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"Inv", "[", "A", "]"}], "[", 
             RowBox[{"{", 
              RowBox[{"x", ",", "y", ",", "z", ",", "a"}], "}"}], "]"}], "[", 
            
            RowBox[{"[", "4", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"And", "[", 
             RowBox[{
              RowBox[{"Not", "[", 
               RowBox[{"MatchQ", "[", 
                RowBox[{"a", ",", "newSlat"}], "]"}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"ifSlatGaugeSet", "[", "newSlat", "]"}], "==", 
               "False"}], " ", ",", 
              RowBox[{"Not", "[", 
               RowBox[{"MemberQ", "[", 
                RowBox[{
                 RowBox[{"findAllDependencies", "[", "a", "]"}], ",", 
                 "newSlat"}], "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"(", " ", 
             RowBox[{
              RowBox[{
               RowBox[{"MAssoc", "[", 
                RowBox[{"{", 
                 RowBox[{"A", ",", "a"}], "}"}], "]"}], "=", 
               RowBox[{
                RowBox[{"SU2", "[", " ", 
                 RowBox[{
                  RowBox[{"M", "[", "A", "]"}], "[", "a", "]"}], "]"}], "->", 
                
                RowBox[{"SU2", "[", "\[Tau]0", "]"}]}]}], ";", 
              RowBox[{
               RowBox[{"ifSlatGaugeSet", "[", "newSlat", "]"}], "=", "True"}],
               ";", "\[IndentingNewLine]", 
              RowBox[{"Print", "[", 
               RowBox[{
               "A", ",", "\"\<*\>\"", ",", "a", ",", "\"\<*\>\"", ",", 
                "newSlat", ",", "\"\<*\>\""}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"Print", "[", 
               RowBox[{"findAllDependencies", "[", "a", "]"}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Dependency", "[", "newSlat", "]"}], "=", "a"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"Print", "[", "Dependency", "]"}], ";"}], ")"}]}], 
           "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"(", " ", 
        RowBox[{
         RowBox[{"trySettingSlatGauge", "[", 
          RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ")"}], "@@@", 
       RowBox[{"Distribute", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "gc", "}"}], ",", "slatList"}], "}"}], ",", "List"}], 
        "]"}]}]}]}], "]"}]}], ";"}]], "Input",
